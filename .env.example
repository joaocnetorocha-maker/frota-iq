# =============================================================================
# FrotaIQ — Variáveis de ambiente
# =============================================================================
# Esse arquivo é só TEMPLATE. Pra ambiente local copie pra `.env`:
#   cp .env.example .env
# E preencha com valores reais. NUNCA commite o `.env` (já tá no .gitignore).
#
# Em produção (Vercel), configure essas mesmas variáveis em:
#   Vercel Dashboard → Project → Settings → Environment Variables
# =============================================================================

# ONIXSAT (webservice da Trucks Control)
ONIX_LOGIN=12978611000198
ONIX_SENHA=112498

# Supabase (banco)
# Pegue em: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # Service role key (NUNCA expor no frontend)

# Segredo do gatilho do cron-job.org
# Use um valor aleatório longo (ex: openssl rand -hex 32)
CRON_SECRET=troque-esse-valor-por-uma-string-aleatoria-bem-grande
